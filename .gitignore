# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# --- Agent skills ---
# SOURCE OF TRUTH is skills/ (tracked, organized by capability).
# The discovery trees below are GENERATED by `npm run skills:sync` —
# never edit them by hand, never commit them.
/.claude/skills/
/.agents/

# machine-local / personal agent files
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock
skills-lock.json
.cursor/settings.json
.cursor/rules/

# next.js
/.next/
# per-user build caches (NEXT_DIST_DIR), e.g. .next-germano
/.next-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# local uploads (max 1GB for preview testing)
/storage

# auis project storage (filesystem-saved projects are user data)
/auis/projects/*
!/auis/projects/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

# local backups
*.bak

# review bridge runtime state (grows unbounded — not source code)
review-bridge/data/*.json
review-bridge/data/.backups/
review-bridge/node_modules/

# flow-bridge runtime state (grows unbounded — not source code)
flow-bridge/data/*.json
flow-bridge/node_modules/

# page-editor runtime state — Live Edit Mode persisted edits (not source code)
page-editor/data/*.json

# Playwright MCP verification artifacts (snapshots/console logs)
.playwright-mcp/

# Local session captures (screenshots + cap JSON refs — not product source)
/g-*.png
/cap-*.json
/germano-perfil.png
/usado-card.png
