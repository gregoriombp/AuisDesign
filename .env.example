# Copy to .env.local and fill in. Anything prefixed with NEXT_PUBLIC_ ships to
# the client — keep secrets out of NEXT_PUBLIC_ vars.

# Auis Review Mode — local annotation overlay (free-draw + pin).
# It is always mounted; toggle commenting from the Auis dot in the bottom-right
# corner or with Cmd+Shift+Y. Hide the dot without disabling the shortcuts:
#NEXT_PUBLIC_AUIS_DOT_DISABLED=true

# Review Bridge — local queue for agents. `npm run dev:bridge` prepares these
# values in `.env.local` and starts the server on 127.0.0.1:9878.
#NEXT_PUBLIC_AUIS_REVIEW_BRIDGE_URL=http://127.0.0.1:9878
#NEXT_PUBLIC_AUIS_REVIEW_TOKEN=generated-automatically-by-npm-run-dev-bridge

# Review Mode — voice transcription and comment suggestions (OpenAI). Used only
# on the server by /api/review/transcribe and /api/review/suggest; it is never
# exposed to the browser. Without it, voice and suggestion actions stay hidden
# while the rest of Review Mode continues to work.
# OPENAI_API_KEY=sk-...
