{
  "name": "auis",
  "version": "1.0.0",
  "description": "Auis — code-native design builder: design system, screens, UX flows, review/edit modes, and agent skills for Next.js + shadcn/ui.",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:solo": "next dev --hostname 127.0.0.1",
    "dev:bridge": "npm run review-bridge:prepare && concurrently -n web,review -c cyan,magenta 'NEXT_PUBLIC_AUIS_REVIEW_BRIDGE_URL=http://127.0.0.1:9878 next dev --hostname 127.0.0.1' 'AUIS_REVIEW_HOST=127.0.0.1 npm run review-bridge:run'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "skills:sync": "node scripts/skills-sync.mjs",
    "skills:catalog": "node scripts/skills-catalog.mjs",
    "predev": "node scripts/skills-sync.mjs",
    "postinstall": "node scripts/skills-sync.mjs",
    "ds:check": "node scripts/ds-check.mjs",
    "review-bridge:prepare": "node scripts/ensure-review-bridge-env.mjs",
    "review-bridge:run": "node scripts/run-review-bridge.mjs",
    "review-bridge": "npm --prefix review-bridge start",
    "review-bridge:dev": "npm --prefix review-bridge run dev",
    "review-bridge:install": "npm --prefix review-bridge install"
  },
  "keywords": [
    "design-system",
    "design-builder",
    "shadcn-ui",
    "nextjs",
    "ai-agents",
    "claude-code",
    "styleguide",
    "ux-flows",
    "design-engineering"
  ],
  "author": "Gregório Pinheiro — Design Engineer UX/UI",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "protobufjs": ">=7.5.5",
    "postcss": "^8.5.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gregoriombp/AuisDesign.git"
  }
}
